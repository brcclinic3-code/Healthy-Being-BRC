<script>
function submitMainForm(e){
  e.preventDefault();
  const first=document.getElementById('mFirst').value;
  const last=document.getElementById('mLast').value;
  const phone=document.getElementById('mPhone').value;
  const service=document.getElementById('mService').value;
  const duration=document.getElementById('mDuration').value||'Not specified';
  const prev=document.getElementById('mPrev').value||'None';
  const msg=document.getElementById('mMessage').value;
  const home=document.getElementById('mHomeVisit').checked;
  const first_time=document.getElementById('mFirstTime').checked;
  const wa=encodeURIComponent(`🏥 BRC Clinic Appointment Request\n\nName: ${first} ${last}\nPhone: ${phone}\nService: ${service}\nProblem Duration: ${duration}\nPrev. Treatment: ${prev}\nHome Visit: ${home?'Yes':'No'}\nFirst Visit: ${first_time?'Yes':'No'}\n\nDescription: ${msg}`);
  window.open(`https://wa.me/919311642999?text=${wa}`,'_blank');
  document.querySelectorAll('.step')[0].classList.remove('active');
  document.querySelectorAll('.step')[0].classList.add('done');
  document.querySelectorAll('.step')[1].classList.add('done');
  document.querySelectorAll('.step')[2].classList.add('active');
  const t=document.getElementById('toast');
  if(t){t.textContent='✅ Appointment request sent via WhatsApp! We will call you back shortly.';t.style.transform='translateX(-50%) translateY(0)';setTimeout(()=>t.style.transform='translateX(-50%) translateY(80px)',5000);}
  e.target.reset();
}
</script>
